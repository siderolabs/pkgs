--- a/drivers/gpu/nvgpu/os/linux/nvhost_host1x.c	2026-04-27 22:24:47
+++ b/drivers/gpu/nvgpu/os/linux/nvhost_host1x.c	2026-04-27 22:25:13
@@ -14,6 +14,7 @@
